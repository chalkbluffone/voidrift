{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "godot: headless sanity check",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"tools/headless_sanity_check.ps1"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "godot: build all platforms",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"tools/build.ps1"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "godot: build windows only",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"tools/build.ps1",
				"-Platform",
				"Windows"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "steam: deploy to steamworks",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"tools/deploy.ps1",
				"-Username",
				"chalkbluffmedia",
				"-SteamCmdExe",
				"F:\\SteamCMD\\steamcmd.exe"
			],
			"isBackground": false,
			"group": "none",
			"problemMatcher": []
		}
	]
}